<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>个人作品集 | Portfolio</title>
<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    :root {
        --primary: #1a1a1a;
        --secondary: #666;
        --border: #e5e5e5;
        --bg: #fafafa;
        --white: #ffffff;
    }

    body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
        color: var(--primary);
        background: var(--bg);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
    }

    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 40px;
    }

    /* 导航栏 */
    nav {
        position: fixed;
        top: 0;
        width: 100%;
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid var(--border);
        z-index: 100;
    }

    .nav-inner {
        display: flex;
        justify-content: space-between;
        align-items: center;
        height: 64px;
    }

    .logo {
        font-size: 18px;
        font-weight: 600;
        letter-spacing: 0.5px;
    }

    .nav-links a {
        margin-left: 32px;
        text-decoration: none;
        color: var(--secondary);
        font-size: 14px;
        transition: color 0.3s;
    }

    .nav-links a:hover {
        color: var(--primary);
    }

    /* Hero 区域 */
    .hero {
        padding: 140px 0 80px;
        text-align: center;
    }

    .hero h1 {
        font-size: 48px;
        font-weight: 300;
        letter-spacing: -1px;
        margin-bottom: 20px;
    }

    .hero p {
        font-size: 16px;
        color: var(--secondary);
        max-width: 600px;
        margin: 0 auto;
    }

    /* 区块通用样式 */
    section {
        padding: 80px 0;
    }

    .section-title {
        font-size: 28px;
        font-weight: 400;
        margin-bottom: 48px;
        text-align: center;
        position: relative;
    }

    .section-title::after {
        content: '';
        display: block;
        width: 40px;
        height: 1px;
        background: var(--primary);
        margin: 16px auto 0;
    }

    /* 作品画廊 */
    .gallery {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 24px;
    }

    .work-item {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 8px;
        overflow: hidden;
        transition: transform 0.3s, box-shadow 0.3s;
    }

    .work-item:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
    }

    .work-media {
        width: 100%;
        aspect-ratio: 4 / 3;
        background: #f0f0f0;
        overflow: hidden;
    }

    .work-media img,
    .work-media video {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .work-info {
        padding: 20px;
    }

    .work-title {
        font-size: 16px;
        font-weight: 500;
        margin-bottom: 6px;
    }

    .work-desc {
        font-size: 13px;
        color: var(--secondary);
    }

    /* 创作流程 */
    .process-timeline {
        max-width: 800px;
        margin: 0 auto;
        position: relative;
    }

    .process-timeline::before {
        content: '';
        position: absolute;
        left: 24px;
        top: 0;
        bottom: 0;
        width: 1px;
        background: var(--border);
    }

    .process-step {
        display: flex;
        margin-bottom: 48px;
        position: relative;
    }

    .process-step:last-child {
        margin-bottom: 0;
    }

    .step-number {
        width: 48px;
        height: 48px;
        border-radius: 50%;
        background: var(--primary);
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 16px;
        font-weight: 500;
        flex-shrink: 0;
        z-index: 1;
    }

    .step-content {
        margin-left: 24px;
        padding-top: 8px;
    }

    .step-title {
        font-size: 18px;
        font-weight: 500;
        margin-bottom: 8px;
    }

    .step-desc {
        font-size: 14px;
        color: var(--secondary);
        line-height: 1.8;
    }

    /* 联系方式 */
    .contact-section {
        background: var(--white);
        border-top: 1px solid var(--border);
    }

    .contact-info {
        max-width: 500px;
        margin: 0 auto;
        text-align: center;
    }

    .contact-item {
        margin-bottom: 20px;
        font-size: 15px;
    }

    .contact-label {
        color: var(--secondary);
        font-size: 13px;
        margin-bottom: 4px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .contact-value {
        font-size: 18px;
        font-weight: 400;
    }

    /* 上传区域 */
    .upload-section {
        background: var(--white);
        border-top: 1px solid var(--border);
    }

    .upload-area {
        max-width: 600px;
        margin: 0 auto;
        border: 2px dashed var(--border);
        border-radius: 12px;
        padding: 48px;
        text-align: center;
        transition: border-color 0.3s, background 0.3s;
        cursor: pointer;
    }

    .upload-area:hover,
    .upload-area.dragover {
        border-color: var(--primary);
        background: #f8f8f8;
    }

    .upload-icon {
        font-size: 32px;
        margin-bottom: 16px;
    }

    .upload-text {
        font-size: 15px;
        margin-bottom: 8px;
    }

    .upload-hint {
        font-size: 13px;
        color: var(--secondary);
    }

    .upload-input {
        display: none;
    }

    .upload-list {
        margin-top: 24px;
    }

    .upload-item {
        display: flex;
        align-items: center;
        padding: 12px 16px;
        background: var(--bg);
        border-radius: 6px;
        margin-bottom: 8px;
        font-size: 14px;
    }

    .upload-item-name {
        flex: 1;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .upload-item-remove {
        color: #999;
        cursor: pointer;
        margin-left: 12px;
        font-size: 18px;
    }

    .upload-item-remove:hover {
        color: #e74c3c;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-group label {
        display: block;
        font-size: 13px;
        color: var(--secondary);
        margin-bottom: 6px;
    }

    .form-group input,
    .form-group textarea {
        width: 100%;
        padding: 10px 12px;
        border: 1px solid var(--border);
        border-radius: 6px;
        font-size: 14px;
        font-family: inherit;
        outline: none;
        transition: border-color 0.3s;
    }

    .form-group input:focus,
    .form-group textarea:focus {
        border-color: var(--primary);
    }

    .btn {
        display: inline-block;
        padding: 12px 32px;
        background: var(--primary);
        color: white;
        border: none;
        border-radius: 6px;
        font-size: 14px;
        cursor: pointer;
        transition: opacity 0.3s;
    }

    .btn:hover {
        opacity: 0.9;
    }

    /* 页脚 */
    footer {
        padding: 32px 0;
        text-align: center;
        color: var(--secondary);
        font-size: 13px;
        border-top: 1px solid var(--border);
        background: var(--white);
    }

    /* 灯箱效果 */
    .lightbox {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.9);
        display: none;
        align-items: center;
        justify-content: center;
        z-index: 1000;
    }

    .lightbox.active {
        display: flex;
    }

    .lightbox-content {
        max-width: 90%;
        max-height: 90%;
    }

    .lightbox-content img,
    .lightbox-content video {
        max-width: 100%;
        max-height: 85vh;
        display: block;
    }

    .lightbox-close {
        position: absolute;
        top: 24px;
        right: 32px;
        color: white;
        font-size: 32px;
        cursor: pointer;
        line-height: 1;
    }

    /* 响应式 */
    @media (max-width: 768px) {
        .container {
            padding: 0 20px;
        }

        .hero h1 {
            font-size: 32px;
        }

        .nav-links a {
            margin-left: 16px;
            font-size: 13px;
        }

        .gallery {
            grid-template-columns: 1fr;
        }

        .upload-area {
            padding: 32px 20px;
        }
    }
</style>
</head>
<body>

<!-- 导航 -->
<nav>
    <div class="container nav-inner">
        <div class="logo" id="navName">我的作品集</div>
        <div class="nav-links">
            <a href="#works">作品</a>
            <a href="#process">流程</a>
            <a href="#contact">联系</a>
            <a href="#upload">上传</a>
        </div>
    </div>
</nav>

<!-- 首页介绍 -->
<section class="hero">
    <div class="container">
        <h1 id="heroName">你的姓名</h1>
        <p id="heroBio">专注于创意设计与视觉表达，用作品讲述故事。以下是我的作品集，涵盖影像、设计与多媒体创作。</p>
    </div>
</section>

<!-- 作品展示 -->
<section id="works">
    <div class="container">
        <h2 class="section-title">作品展示</h2>
        <div class="gallery" id="gallery">
            <!-- 示例作品，上传后会动态添加 -->
            <div class="work-item">
                <div class="work-media">
                    <img src="https://picsum.photos/800/600?random=1" alt="作品示例">
                </div>
                <div class="work-info">
                    <div class="work-title">示例作品一</div>
                    <div class="work-desc">创意摄影 / 2024</div>
                </div>
            </div>
            <div class="work-item">
                <div class="work-media">
                    <img src="https://picsum.photos/800/600?random=2" alt="作品示例">
                </div>
                <div class="work-info">
                    <div class="work-title">示例作品二</div>
                    <div class="work-desc">品牌设计 / 2024</div>
                </div>
            </div>
            <div class="work-item">
                <div class="work-media">
                    <img src="https://picsum.photos/800/600?random=3" alt="作品示例">
                </div>
                <div class="work-info">
                    <div class="work-title">示例作品三</div>
                    <div class="work-desc">短片创作 / 2024</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- 创作流程 -->
<section id="process" style="background: var(--white); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);">
    <div class="container">
        <h2 class="section-title">创作流程</h2>
        <div class="process-timeline">
            <div class="process-step">
                <div class="step-number">01</div>
                <div class="step-content">
                    <div class="step-title">需求沟通与构思</div>
                    <div class="step-desc">深入了解项目背景与目标受众，明确核心诉求。通过头脑风暴与参考收集，确定整体风格方向与创意概念，输出初步方案。</div>
                </div>
            </div>
            <div class="process-step">
                <div class="step-number">02</div>
                <div class="step-content">
                    <div class="step-title">方案设计与草图</div>
                    <div class="step-desc">基于构思进行视觉化表达，绘制多版草图与分镜。不断迭代优化，选取最优方向进行深化，确保视觉与内容高度统一。</div>
                </div>
            </div>
            <div class="process-step">
                <div class="step-number">03</div>
                <div class="step-content">
                    <div class="step-title">执行制作与打磨</div>
                    <div class="step-desc">进入正式制作阶段，包括拍摄、绘制、剪辑或动效制作。注重细节把控，在过程中持续调整，确保成品质量达到预期标准。</div>
                </div>
            </div>
            <div class="process-step">
                <div class="step-number">04</div>
                <div class="step-content">
                    <div class="step-title">交付与反馈优化</div>
                    <div class="step-desc">完成初稿后交付审阅，收集反馈意见并进行针对性调整。最终输出高质量成品文件，并提供后续的技术支持与答疑。</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- 联系方式 -->
<section id="contact" class="contact-section">
    <div class="container">
        <h2 class="section-title">联系方式</h2>
        <div class="contact-info">
            <div class="contact-item">
                <div class="contact-label">姓名</div>
                <div class="contact-value" id="contactName">你的姓名</div>
            </div>
            <div class="contact-item">
                <div class="contact-label">电话</div>
                <div class="contact-value" id="contactPhone">138-XXXX-XXXX</div>
            </div>
            <div class="contact-item">
                <div class="contact-label">邮箱</div>
                <div class="contact-value" id="contactEmail">your@email.com</div>
            </div>
            <div class="contact-item">
                <div class="contact-label">微信</div>
                <div class="contact-value" id="contactWechat">your_wechat_id</div>
            </div>
        </div>
    </div>
</section>

<!-- 上传区域 -->
<section id="upload" class="upload-section">
    <div class="container">
        <h2 class="section-title">上传作品</h2>
        <div style="max-width: 600px; margin: 0 auto;">
            <div class="form-group">
                <label>作品标题</label>
                <input type="text" id="workTitle" placeholder="请输入作品名称">
            </div>
            <div class="form-group">
                <label>作品描述</label>
                <textarea id="workDesc" rows="2" placeholder="简要介绍作品类型、创作时间等"></textarea>
            </div>
            
            <div class="upload-area" id="uploadArea">
                <div class="upload-icon">+</div>
                <div class="upload-text">点击或拖拽文件到此处上传</div>
                <div class="upload-hint">支持 JPG、PNG、MP4 等格式，单个文件不超过 100MB</div>
                <input type="file" class="upload-input" id="fileInput" accept="image/*,video/*" multiple>
            </div>
            
            <div class="upload-list" id="uploadList"></div>
            
            <div style="text-align: center; margin-top: 24px;">
                <button class="btn" onclick="addWork()">添加到作品集</button>
            </div>
        </div>
    </div>
</section>

<!-- 页脚 -->
<footer>
    <div class="container">
        <p>© 2024 个人作品集 · All Rights Reserved</p>
    </div>
</footer>

<!-- 灯箱 -->
<div class="lightbox" id="lightbox">
    <span class="lightbox-close" onclick="closeLightbox()">×</span>
    <div class="lightbox-content" id="lightboxContent"></div>
</div>

<script>
    // 待上传文件列表
    let pendingFiles = [];

    // 上传区域交互
    const uploadArea = document.getElementById('uploadArea');
    const fileInput = document.getElementById('fileInput');
    const uploadList = document.getElementById('uploadList');

    uploadArea.addEventListener('click', () => fileInput.click());

    uploadArea.addEventListener('dragover', (e) => {
        e.preventDefault();
        uploadArea.classList.add('dragover');
    });

    uploadArea.addEventListener('dragleave', () => {
        uploadArea.classList.remove('dragover');
    });

    uploadArea.addEventListener('drop', (e) => {
        e.preventDefault();
        uploadArea.classList.remove('dragover');
        handleFiles(e.dataTransfer.files);
    });

    fileInput.addEventListener('change', (e) => {
        handleFiles(e.target.files);
    });

    function handleFiles(files) {
        for (let file of files) {
            if (file.type.startsWith('image/') || file.type.startsWith('video/')) {
                pendingFiles.push(file);
            }
        }
        renderUploadList();
    }

    function renderUploadList() {
        uploadList.innerHTML = '';
        pendingFiles.forEach((file, index) => {
            const item = document.createElement('div');
            item.className = 'upload-item';
            item.innerHTML = `
                <span class="upload-item-name">${file.name} (${(file.size / 1024 / 1024).toFixed(2)} MB)</span>
                <span class="upload-item-remove" onclick="removeFile(${index})">×</span>
            `;
            uploadList.appendChild(item);
        });
    }

    function removeFile(index) {
        pendingFiles.splice(index, 1);
        renderUploadList();
    }

    // 添加作品到画廊
    function addWork() {
        const title = document.getElementById('workTitle').value.trim() || '未命名作品';
        const desc = document.getElementById('workDesc').value.trim() || '暂无描述';

        if (pendingFiles.length === 0) {
            alert('请先选择要上传的文件');
            return;
        }

        const gallery = document.getElementById('gallery');

        pendingFiles.forEach(file => {
            const reader = new FileReader();
            reader.onload = function(e) {
                const item = document.createElement('div');
                item.className = 'work-item';
                
                let mediaHtml = '';
                if (file.type.startsWith('image/')) {
                    mediaHtml = `<img src="${e.target.result}" alt="${title}" onclick="openLightbox('${e.target.result}', 'image')">`;
                } else {
                    mediaHtml = `<video src="${e.target.result}" controls onclick="event.stopPropagation()"></video>`;
                }

                item.innerHTML = `
                    <div class="work-media">${mediaHtml}</div>
                    <div class="work-info">
                        <div class="work-title">${title}</div>
                        <div class="work-desc">${desc}</div>
                    </div>
                `;
                gallery.insertBefore(item, gallery.firstChild);
            };
            reader.readAsDataURL(file);
        });

        // 清空
        pendingFiles = [];
        renderUploadList();
        document.getElementById('workTitle').value = '';
        document.getElementById('workDesc').value = '';
        fileInput.value = '';

        alert('作品已添加！注意：刷新页面后本地上传的作品会消失，如需永久保存请部署后端。');
    }

    // 灯箱功能
    function openLightbox(src, type) {
        const lightbox = document.getElementById('lightbox');
        const content = document.getElementById('lightboxContent');
        
        if (type === 'image') {
            content.innerHTML = `<img src="${src}">`;
        } else {
            content.innerHTML = `<video src="${src}" controls autoplay></video>`;
        }
        
        lightbox.classList.add('active');
    }

    function closeLightbox() {
        document.getElementById('lightbox').classList.remove('active');
        document.getElementById('lightboxContent').innerHTML = '';
    }

    document.getElementById('lightbox').addEventListener('click', function(e) {
        if (e.target === this) closeLightbox();
    });

    // 平滑滚动
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function(e) {
            e.preventDefault();
            const target = document.querySelector(this.getAttribute('href'));
            if (target) {
                target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
        });
    });

    // ===== 配置区：修改这里的信息即可 =====
    const config = {
        name: "张三",
        bio: "专注于创意设计与视觉表达，用作品讲述故事。以下是我的作品集，涵盖影像、设计与多媒体创作。",
        phone: "138-0000-0000",
        email: "zhangsan@example.com",
        wechat: "zhangsan_design"
    };

    document.getElementById('navName').textContent = config.name + ' · 作品集';
    document.getElementById('heroName').textContent = config.name;
    document.getElementById('heroBio').textContent = config.bio;
    document.getElementById('contactName').textContent = config.name;
    document.getElementById('contactPhone').textContent = config.phone;
    document.getElementById('contactEmail').textContent = config.email;
    document.getElementById('contactWechat').textContent = config.wechat;
    document.title = config.name + ' | 个人作品集';
</script>

</body>
</html>
